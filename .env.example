# 和风天气 API 配置示例
# 复制此文件为 .env 并填入你的配置

# API 主机地址(必需)
# 免费版: devapi.qweather.com
# 商业版: your-custom-domain.qweatherapi.com
HEFENG_API_HOST=your-domain.qweatherapi.com

# API KEY 认证(推荐)
HEFENG_API_KEY=your_api_key_here

# JWT 数字签名认证(可选,与API KEY二选一)
# 如果使用JWT认证,需要配置以下三个参数
# HEFENG_PROJECT_ID=your_project_id
# HEFENG_KEY_ID=your_key_id
# HEFENG_PRIVATE_KEY_PATH=./ed25519-private.pem
# HEFENG_PRIVATE_KEY=your_private_key_content
